<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="controlPane" prefWidth="250" spacing="12"
      xmlns:fx="http://javafx.com/fxml"
      style="-fx-background-color: #2c2c2c; -fx-padding: 15;">

    <!-- SIGN IN TITLE -->
    <Label text="Sign in to Save Projects"
           style="-fx-text-fill: white; -fx-font-size: 16px;" />

    <!-- EMAIL FIELD -->
    <TextField fx:id="emailField" promptText="Email" />

    <!-- PASSWORD FIELD -->
    <PasswordField fx:id="passwordField" promptText="Password" />

    <!-- BUTTON ROW -->
    <HBox spacing="10">
        <Button text="Register" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button text="Sign In" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>

    <!-- DROPDOWN -->
    <Label text="Focus Object" style="-fx-text-fill: white;" />
    <ComboBox fx:id="focusDropdown" promptText="Select object" />

    <!-- DATA DISPLAY -->
    <GridPane hgap="10" vgap="8">

        <Label text="Mass:" style="-fx-text-fill: white;" GridPane.rowIndex="0"/>
        <Label fx:id="massLabel" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Radius (km):" style="-fx-text-fill: white;" GridPane.rowIndex="1"/>
        <Label fx:id="radiusLabel" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Semimajor Axis (AU):" style="-fx-text-fill: white;" GridPane.rowIndex="2"/>
        <Label fx:id="axisLabel" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Eccentricity:" style="-fx-text-fill: white;" GridPane.rowIndex="3"/>
        <Label fx:id="eccLabel" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Inclination:" style="-fx-text-fill: white;" GridPane.rowIndex="4"/>
        <Label fx:id="inclinationLabel" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Ascending Node:" style="-fx-text-fill: white;" GridPane.rowIndex="5"/>
        <Label fx:id="nodeLabel" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Arg. of Periapsis:" style="-fx-text-fill: white;" GridPane.rowIndex="6"/>
        <Label fx:id="periapsisLabel" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

    </GridPane>

</VBox>